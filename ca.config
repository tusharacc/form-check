# code-assistant project configuration
# Auto-generated on first launch — values shown are your current effective defaults.
# Uncomment and edit any line to override it for this project only.
# Restart `ca` after saving.  Run `/config` to see the active source of each setting.
#
# Machine-level settings live in: ~/.code-assistant/config.toml
# Settings NOT listed here (feedback, sessions, log dirs) can only go there.

# ── Device / GPU ─────────────────────────────────────────────────────────────
# device = "auto"   # auto | cpu | metal | cuda

# ── Models ───────────────────────────────────────────────────────────────────
architect_model   = "qwen2.5-coder:32b"
implementer_model = "qwen2.5-coder:32b"
reviewer_model    = "qwen2.5-coder:32b"
tester_model      = "qwen2.5-coder:32b"
#
# Classification model (intent routing — keep this small and fast)
# classification_model = ""

# ── Inference ────────────────────────────────────────────────────────────────
# num_ctx     = 8192     # context window tokens (don't exceed available RAM)
# num_threads = 12      # CPU inference threads
# temperature = 0.2    # 0.0 = deterministic, 1.0 = creative

# ── Pipeline & debate ────────────────────────────────────────────────────────
# use_pipeline  = true   # arch → impl → review → test → docs
# auto_approve  = true    # auto-approve write_file / edit_file / run_shell
# debate_enabled = true
# debate_rounds  = 2

# ── RAG ──────────────────────────────────────────────────────────────────────
# rag_top_k        = 5
# rag_always_query = false

# ── Web tools ────────────────────────────────────────────────────────────────
# web_search_enabled = false   # requires duckduckgo-search or serper_api_key

# ── Feature flags ────────────────────────────────────────────────────────────
# project_context_enabled = true
